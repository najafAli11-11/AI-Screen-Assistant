# ---- Required before the assistant can answer ----
# Anthropic API key (Claude vision). This is the only value you must add.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: base URL of an Anthropic-compatible API proxy/reseller.
# Leave empty to use the official Anthropic API.
ANTHROPIC_BASE_URL=

# ---- Access control (change both before exposing the app publicly) ----
# Signs short-lived session tokens. Use 32+ random bytes in production.
JWT_SECRET=change-this-to-a-random-secret-in-production
# The access code the web/Android clients exchange for a token.
PRE_SHARED_SECRET=change-this-to-a-different-random-secret

# ---- Runtime ----
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# ---- Speech-to-text ----
# tiny/base/small/medium/large-v3. "small" runs on modest hardware and loads
# fast; move up to medium or large-v3 for the best Urdu accuracy if you have
# the RAM and a GPU. Default keeps the app usable out of the box.
WHISPER_MODEL=small

# ---- Text-to-speech ----
# gtts (free, no key) or elevenlabs (higher quality, needs the key below).
TTS_PROVIDER=gtts
ELEVENLABS_API_KEY=

# ---- Limits ----
SESSION_TTL_MINUTES=30
MAX_QUERIES_PER_MINUTE=20
# ~1280px JPEG frames at 70% quality; keep headroom above the client target.
MAX_FRAME_BYTES=900000
MAX_AUDIO_BYTES=2500000

# ---- Android APK download page ----
APK_DOWNLOAD_URL=
